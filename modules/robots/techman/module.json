{
  "id": "robot_techman",
  "name": "Techman TM",
  "version": "1.2.0",
  "category": "robot",
  "description": "Techman TM 로봇 드라이버",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/techman"
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-moveit"
    ],
    "pip": []
  },
  "check": {
    "type": "path"
  },
  "robots": [
    {
      "type": "tm_12",
      "spec": {
        "company": "Techman",
        "role": "single_arm",
        "joint_dim": 6,
        "joint_names": [
          "joint_1",
          "joint_2",
          "joint_3",
          "joint_4",
          "joint_5",
          "joint_6"
        ],
        "joint_lower_bounds": [
          -6.283,
          -6.283,
          -2.827,
          -6.283,
          -6.283,
          -6.283
        ],
        "joint_upper_bounds": [
          6.283,
          6.283,
          2.827,
          6.283,
          6.283,
          6.283
        ],
        "tool_inner": false,
        "tool_index": [],
        "ik_available": true,
        "custom_fields": [
          "ip_address"
        ]
      },
      "driver": {
        "kind": "service",
        "read_topic": "/joint_states",
        "read_topic_msg": "sensor_msgs/JointState",
        "write_type": "service",
        "write_topic": "/send_script",
        "write_topic_msg": "tm_msgs/srv/SendScript",
        "launch": {
          "package": "tm_driver",
          "launch_file": "tm_bringup.launch.py",
          "args": {
            "namespace": "{namespace}",
            "robot_ip": "{ip_address|192.168.1.10}"
          }
        }
      },
      "ik": {
        "urdf_path": "{ros2_root}/tm_description/urdf/tm12s.urdf",
        "urdf_package_dir": "{ros2_root}/tm_description/",
        "joints_to_lock": [],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint_6",
            "offset": [
              0.0,
              0.0,
              0.15
            ]
          }
        ]
      }
    },
    {
      "type": "tm_12s",
      "spec": {
        "company": "Techman",
        "role": "single_arm",
        "joint_dim": 6,
        "joint_names": [
          "joint_1",
          "joint_2",
          "joint_3",
          "joint_4",
          "joint_5",
          "joint_6"
        ],
        "joint_lower_bounds": [
          -6.283,
          -6.283,
          -2.827,
          -6.283,
          -6.283,
          -6.283
        ],
        "joint_upper_bounds": [
          6.283,
          6.283,
          2.827,
          6.283,
          6.283,
          6.283
        ],
        "tool_inner": false,
        "tool_index": [],
        "ik_available": true,
        "custom_fields": [
          "ip_address"
        ]
      },
      "driver": {
        "kind": "service",
        "read_topic": "/joint_states",
        "read_topic_msg": "sensor_msgs/JointState",
        "write_type": "service",
        "write_topic": "/send_script",
        "write_topic_msg": "tm_msgs/srv/SendScript",
        "launch": {
          "package": "tm_driver",
          "launch_file": "tm_bringup.launch.py",
          "args": {
            "namespace": "{namespace}",
            "robot_ip": "{ip_address|192.168.1.10}"
          }
        }
      },
      "ik": {
        "urdf_path": "{ros2_root}/tm_description/urdf/tm12s.urdf",
        "urdf_package_dir": "{ros2_root}/tm_description/",
        "joints_to_lock": [],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint_6",
            "offset": [
              0.0,
              0.0,
              0.15
            ]
          }
        ]
      }
    },
    {
      "type": "tm_12_robotiq",
      "spec": {
        "company": "Techman",
        "role": "single_arm",
        "joint_dim": 7,
        "joint_names": [
          "joint_1",
          "joint_2",
          "joint_3",
          "joint_4",
          "joint_5",
          "joint_6",
          "gripper"
        ],
        "joint_lower_bounds": [
          -6.283,
          -6.283,
          -2.827,
          -6.283,
          -6.283,
          -6.283,
          0.0
        ],
        "joint_upper_bounds": [
          6.283,
          6.283,
          2.827,
          6.283,
          6.283,
          6.283,
          0.85
        ],
        "tool_inner": true,
        "tool_index": [
          6
        ],
        "ik_available": true,
        "custom_fields": [
          "ip_address"
        ]
      },
      "driver": {
        "kind": "service",
        "read_topic": "/feedback_states",
        "read_topic_msg": "tm_msgs/msg/FeedbackState",
        "write_type": "service",
        "write_topic": "/send_script",
        "write_topic_msg": "tm_msgs/srv/SendScript",
        "launch": {
          "package": "tm_driver",
          "launch_file": "tm_bringup.launch.py",
          "args": {
            "namespace": "{namespace}",
            "robot_ip": "{ip_address|192.168.1.10}"
          }
        }
      },
      "ik": {
        "urdf_path": "{ros2_root}/tm_description/urdf/tm12s.urdf",
        "urdf_package_dir": "{ros2_root}/tm_description/",
        "joints_to_lock": [],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint_6",
            "offset": [
              0.0,
              0.0,
              0.15
            ]
          }
        ]
      }
    }
  ]
}