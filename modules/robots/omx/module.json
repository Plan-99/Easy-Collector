{
  "id": "robot_omx",
  "name": "OMX",
  "version": "1.0.0",
  "category": "robot",
  "description": "ROBOTIS OMX: 5-DOF arm + 1-DOF revolute gripper (gripper_joint_2 mimics gripper_joint_1). Dynamixel USB serial bridge via ros2_control. Arm + gripper are driven as a single JointGroupPositionController over /joint_group_position_controller/commands.",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-ros2-control",
      "ros-humble-ros2-controllers",
      "ros-humble-dynamixel-sdk",
      "ros-humble-dynamixel-hardware-interface",
      "ros-humble-xacro"
    ],
    "pip": []
  },
  "check": {
    "type": "path"
  },
  "robots": [
    {
      "type": "omx_f",
      "spec": {
        "company": "ROBOTIS",
        "role": "single_arm",
        "joint_dim": 6,
        "joint_names": [
          "joint1",
          "joint2",
          "joint3",
          "joint4",
          "joint5",
          "gripper_joint_1"
        ],
        "joint_lower_bounds": [
          -6.283185307179586,
          -6.283185307179586,
          -6.283185307179586,
          -6.283185307179586,
          -6.283185307179586,
          -6.283185307179586
        ],
        "joint_upper_bounds": [
          6.283185307179586,
          6.283185307179586,
          6.283185307179586,
          6.283185307179586,
          6.283185307179586,
          6.283185307179586
        ],
        "tool_inner": true,
        "tool_index": [
          5
        ],
        "ik_available": true,
        "custom_fields": [
          "port_name"
        ]
      },
      "driver": {
        "kind": "topic",
        "interpolation": true,
        "read_topic": "/joint_states",
        "read_topic_msg": "sensor_msgs/JointState",
        "write_topic": "/joint_group_position_controller/commands",
        "write_topic_msg": "std_msgs/Float64MultiArray",
        "pre_launch": [
          {
            "type": "script",
            "path": "install_udev_rules.sh",
            "root": "ros2",
            "wait_after": 0.5
          }
        ],
        "launch": {
          "package": "open_manipulator_bringup",
          "launch_file": "omx_f_easytrainer.launch.py",
          "args": {
            "namespace": "{namespace}",
            "port_name": "{port_name|/dev/ttyACM0}",
            "use_mock_hardware": "false"
          }
        }
      },
      "ik": {
        "urdf_path": "{ros2_root}/open_manipulator_description/urdf/omx_f/omx_f.urdf",
        "urdf_package_dir": "{ros2_root}/open_manipulator_description/",
        "joints_to_lock": [
          "gripper_joint_1",
          "gripper_joint_2"
        ],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint5",
            "offset": [
              0.09193,
              -0.0016,
              0.0
            ]
          }
        ]
      }
    }
  ]
}
