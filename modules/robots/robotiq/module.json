{
  "id": "gripper_robotiq",
  "name": "Robotiq Gripper",
  "version": "1.0.2",
  "category": "robot",
  "description": "Robotiq 그리퍼 드라이버",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/robotiq"
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-ros2-control"
    ],
    "pip": []
  },
  "check": {
    "type": "path"
  }
}
