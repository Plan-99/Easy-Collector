{
  "id": "gripper_robotiq",
  "name": "Robotiq Gripper",
  "version": "1.2.0",
  "category": "robot",
  "description": "Robotiq 2F-85 / 2F-140 그리퍼 (pyRobotiqGripper Modbus RTU SDK 직접 제어). ROS action 경유 없이 USB/RS485 직렬로 바로 명령.",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/robotiq"
    }
  },
  "dependencies": {
    "apt": [],
    "pip": [
      "pyRobotiqGripper>=3.2.0",
      "pymodbus>=3.12.1",
      "pyserial>=3.5"
    ]
  },
  "check": {
    "type": "path"
  },
  "robots": [
    {
      "type": "robotiq_2f_85",
      "spec": {
        "company": "Robotiq",
        "role": "tool",
        "joint_dim": 1,
        "joint_names": [
          "robotiq_85_left_knuckle_joint"
        ],
        "joint_lower_bounds": [
          0.0
        ],
        "joint_upper_bounds": [
          0.85
        ],
        "tool_inner": false,
        "tool_index": [],
        "ik_available": false,
        "custom_fields": [
          "serial_port"
        ]
      },
      "driver": {
        "kind": "sdk",
        "interpolation": true,
        "sdk_control": true,
        "sdk_type": "robotiq"
      }
    }
  ]
}
