{
  "id": "robot_piper",
  "name": "Piper",
  "version": "1.4.0",
  "category": "robot",
  "description": "Agilex Piper 로봇. SDK 직접 제어와 ROS 토픽 제어 두 가지 모드 모두 제공. CAN 인터페이스는 robot:start 시 자동 감지·구성 (단일팔·양팔 모두 지원).",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/piper",
      "install_cmd": "pip3 install -e ."
    }
  },
  "dependencies": {
    "apt": [
      "can-utils",
      "ethtool"
    ],
    "pip": [
      "python-can>=4.3.1",
      "scipy",
      "piper_sdk"
    ]
  },
  "check": {
    "type": "path"
  },
  "robots": [
    {
      "type": "piper",
      "spec": {
        "company": "Piper",
        "role": "single_arm",
        "joint_dim": 7,
        "joint_names": [
          "joint1",
          "joint2",
          "joint3",
          "joint4",
          "joint5",
          "joint6",
          "gripper"
        ],
        "joint_lower_bounds": [
          -2.618,
          0,
          -2.618,
          -1.745,
          -1.22,
          -2.094,
          0
        ],
        "joint_upper_bounds": [
          2.618,
          2.618,
          0,
          1.745,
          1.22,
          2.094,
          0.087
        ],
        "tool_inner": true,
        "tool_index": [
          6
        ],
        "ik_available": true,
        "custom_fields": [
          "can_port"
        ]
      },
      "driver": {
        "kind": "sdk",
        "interpolation": true,
        "sdk_control": true,
        "sdk_type": "piper",
        "pre_launch": [
          {
            "type": "script",
            "path": "can_activate_main.sh",
            "root": "sdk",
            "wait_after": 1.0
          }
        ]
      },
      "ik": {
        "urdf_path": "{ros2_root}/piper_description/urdf/piper_description.urdf",
        "urdf_package_dir": "{ros2_root}/piper_description/",
        "joints_to_lock": [
          "joint6_to_gripper_base",
          "joint7",
          "joint8"
        ],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint7",
            "offset": null
          }
        ]
      }
    },
    {
      "type": "piper(no gripper)",
      "spec": {
        "company": "Piper",
        "role": "single_arm",
        "joint_dim": 6,
        "joint_names": [
          "joint1",
          "joint2",
          "joint3",
          "joint4",
          "joint5",
          "joint6"
        ],
        "joint_lower_bounds": [
          -2.618,
          0,
          -2.618,
          -1.745,
          -1.22,
          -2.094
        ],
        "joint_upper_bounds": [
          2.618,
          2.618,
          0,
          1.745,
          1.22,
          2.094
        ],
        "tool_inner": false,
        "tool_index": [],
        "ik_available": true,
        "custom_fields": [
          "can_port"
        ]
      },
      "driver": {
        "kind": "sdk",
        "interpolation": true,
        "sdk_control": true,
        "sdk_type": "piper",
        "pre_launch": [
          {
            "type": "script",
            "path": "can_activate_main.sh",
            "root": "sdk",
            "wait_after": 1.0
          }
        ]
      },
      "ik": {
        "urdf_path": "{ros2_root}/piper_description/urdf/piper_no_gripper_description.urdf",
        "urdf_package_dir": "{ros2_root}/piper_description/",
        "joints_to_lock": [],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint6",
            "offset": [
              0.2,
              0.0,
              0.0
            ]
          }
        ]
      }
    },
    {
      "type": "piper_ros",
      "spec": {
        "company": "Piper",
        "role": "single_arm",
        "joint_dim": 7,
        "joint_names": [
          "joint1",
          "joint2",
          "joint3",
          "joint4",
          "joint5",
          "joint6",
          "gripper"
        ],
        "joint_lower_bounds": [
          -2.618,
          0,
          -2.618,
          -1.745,
          -1.22,
          -2.094,
          0
        ],
        "joint_upper_bounds": [
          2.618,
          2.618,
          0,
          1.745,
          1.22,
          2.094,
          0.087
        ],
        "tool_inner": true,
        "tool_index": [
          6
        ],
        "ik_available": true,
        "custom_fields": [
          "can_port"
        ]
      },
      "driver": {
        "kind": "topic",
        "interpolation": true,
        "read_topic": "/joint_states_single",
        "read_topic_msg": "sensor_msgs/JointState",
        "write_type": "topic",
        "write_topic": "/joint_states",
        "write_topic_msg": "sensor_msgs/JointState",
        "pre_launch": [
          {
            "type": "script",
            "path": "can_activate_main.sh",
            "root": "ros2",
            "wait_after": 1.0
          }
        ],
        "launch": {
          "package": "piper",
          "launch_file": "start_single_piper.launch.py",
          "args": {
            "namespace": "{namespace}",
            "can_port": "{can_port|can0}",
            "auto_enable": "true",
            "rviz_ctrl_flag": "false",
            "gripper_exist": "true"
          }
        }
      },
      "ik": {
        "urdf_path": "{ros2_root}/piper_description/urdf/piper_description.urdf",
        "urdf_package_dir": "{ros2_root}/piper_description/",
        "joints_to_lock": [
          "joint6_to_gripper_base",
          "joint7",
          "joint8"
        ],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint7",
            "offset": null
          }
        ]
      }
    },
    {
      "type": "piper_ros_no_gripper",
      "spec": {
        "company": "Piper",
        "role": "single_arm",
        "joint_dim": 6,
        "joint_names": [
          "joint1",
          "joint2",
          "joint3",
          "joint4",
          "joint5",
          "joint6"
        ],
        "joint_lower_bounds": [
          -2.618,
          0,
          -2.618,
          -1.745,
          -1.22,
          -2.094
        ],
        "joint_upper_bounds": [
          2.618,
          2.618,
          0,
          1.745,
          1.22,
          2.094
        ],
        "tool_inner": false,
        "tool_index": [],
        "ik_available": true,
        "custom_fields": [
          "can_port"
        ]
      },
      "driver": {
        "kind": "topic",
        "interpolation": true,
        "read_topic": "/joint_states_single",
        "read_topic_msg": "sensor_msgs/JointState",
        "write_type": "topic",
        "write_topic": "/joint_states",
        "write_topic_msg": "sensor_msgs/JointState",
        "launch": {
          "package": "piper",
          "launch_file": "start_single_piper.launch.py",
          "args": {
            "namespace": "{namespace}",
            "can_port": "{can_port}",
            "auto_enable": "true",
            "rviz_ctrl_flag": "false",
            "gripper_exist": "false"
          }
        },
        "pre_launch": [
          {
            "type": "script",
            "path": "can_activate_main.sh",
            "root": "ros2",
            "wait_after": 1.0
          }
        ]
      },
      "ik": {
        "urdf_path": "{ros2_root}/piper_description/urdf/piper_no_gripper_description.urdf",
        "urdf_package_dir": "{ros2_root}/piper_description/",
        "joints_to_lock": [],
        "ee_definitions": [
          {
            "name": "ee",
            "parent": "joint6",
            "offset": [
              0.2,
              0.0,
              0.0
            ]
          }
        ]
      }
    }
  ]
}