{
  "id": "robot_piper",
  "name": "Piper",
  "version": "1.0.0",
  "category": "robot",
  "description": "Agilex Piper 로봇 드라이버",
  "install": {
    "ros2": {
      "target": "ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "robot_sdk/piper"
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-moveit",
      "ros-humble-ros2-control",
      "ros-humble-ros2-controllers"
    ],
    "pip": [
      "piper_sdk"
    ]
  }
}
