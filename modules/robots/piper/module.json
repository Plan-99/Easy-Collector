{
  "id": "robot_piper",
  "name": "Piper",
  "version": "1.0.2",
  "category": "robot",
  "description": "Agilex Piper 로봇 드라이버",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/piper",
      "install_cmd": "pip3 install -e ."
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-ros2-control",
      "ros-humble-ros2-controllers",
      "ros-humble-controller-manager",
      "ros-humble-moveit",
      "ros-humble-xacro",
      "can-utils",
      "ethtool"
    ],
    "pip": [
      "python-can>=4.3.1",
      "scipy"
    ]
  }
}