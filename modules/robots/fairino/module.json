{
  "id": "robot_fairino",
  "name": "Fairino",
  "version": "1.1.0",
  "category": "robot",
  "description": "Fairino 협동로봇 (fairino-python-sdk 직접 제어)",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "colcon"
    },
    "sdk": {
      "target": "ros2/robot_sdk/fairino"
    }
  },
  "dependencies": {
    "apt": [
      "ros-humble-moveit"
    ],
    "pip": []
  },
  "check": {
    "type": "path"
  }
}
