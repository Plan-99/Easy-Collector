{
  "id": "sensor_realsense",
  "name": "Intel RealSense",
  "version": "1.3.0",
  "category": "sensor",
  "description": "Intel RealSense 색상 카메라 (D435 / D405 — 색상 스트림 사용).",
  "install": {
    "ros2": {
      "target": "ros2/ros2_ws/src",
      "build": "none"
    }
  },
  "check": {
    "type": "apt",
    "packages": ["ros-humble-realsense2-camera"]
  },
  "dependencies": {
    "apt": [
      "ros-humble-realsense2-camera",
      "ros-humble-realsense2-description"
    ],
    "pip": []
  },
  "sensors": [
    {
      "type": "realsense_d435_color",
      "spec": {
        "company": "Intel",
        "role": "rgb_camera",
        "topic_type": "color",
        "read_topic": "/camera/color/image_raw/compressed",
        "read_topic_msg": "sensor_msgs/CompressedImage",
        "custom_fields": ["serial_number"],
        "resolution": [1280, 720]
      },
      "driver": {
        "kind": "topic",
        "launch": {
          "package": "realsense2_camera",
          "launch_file": "rs_launch.py",
          "args": {
            "camera_namespace": "{namespace}",
            "serial_no": "\"{serial_number}\"",
            "enable_depth": "false",
            "enable_infra1": "false",
            "enable_infra2": "false"
          }
        }
      }
    },
    {
      "type": "realsense_d405_color",
      "spec": {
        "company": "Intel",
        "role": "rgb_camera",
        "topic_type": "color",
        "read_topic": "/camera/color/image_rect_raw/compressed",
        "read_topic_msg": "sensor_msgs/CompressedImage",
        "custom_fields": ["serial_number"],
        "resolution": [848, 480]
      },
      "driver": {
        "kind": "topic",
        "launch": {
          "package": "realsense2_camera",
          "launch_file": "rs_launch.py",
          "args": {
            "camera_namespace": "{namespace}",
            "serial_no": "\"{serial_number}\"",
            "enable_depth": "false",
            "enable_infra1": "false",
            "enable_infra2": "false"
          }
        }
      }
    }
  ]
}
