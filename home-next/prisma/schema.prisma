generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"
  plan          String    @default("free") // "free" | "business"

  // Onboarding profile (collected on first login after Google OAuth)
  organization String?
  department   String?
  jobRole      String?

  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  refundAcceptedAt  DateTime?

  // Optional password (bcrypt hash). Set later from dashboard so the user
  // can sign in with email + password in addition to Google OAuth. Sign-up
  // is still Google-only; this just adds an alt sign-in path for the same
  // already-verified email.
  passwordHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  devices      Device[]
  deviceAuths  DeviceAuthRequest[]
  entitlements Entitlement[]
  payments     Payment[]
  billingKeys  BillingKey[]
  orders       Order[]
  addresses    Address[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// One active install per user. Bound to a stable machineId (sha256 of /etc/machine-id etc.).
// accessToken is the Bearer token the launcher sends on every request.
model Device {
  id          String   @id @default(cuid())
  userId      String
  machineId   String   @unique
  hostname    String?
  os          String?
  accessToken String   @unique
  active      Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Short-lived OAuth-device-flow record. Launcher polls `nonce`; web page approves.
model DeviceAuthRequest {
  nonce      String   @id
  machineId  String
  hostname   String?
  os         String?
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED | CONSUMED
  userId     String?
  deviceId   String?
  errorCode  String?  // e.g. "DEVICE_ALREADY_BOUND"
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([machineId])
}

// Catalog of installable modules. id matches launcher MODULE_REGISTRY id.
// Columns marked "(launcher metadata)" are pulled by the launcher on startup
// to render the install wizard — moves source-of-truth out of Python source.
model Module {
  id          String   @id // e.g. "robot_piper"
  name        String
  category    String   // "robot" | "sensor" | "extension" (visible) | "core" | "feature" (hidden)
  description String?
  priceKrw    Int      @default(0) // 0 = free
  active      Boolean  @default(true)

  // Launcher metadata (used to be hardcoded in release/ui/modules.py)
  required         Boolean  @default(false) // core/feature → true (always installed, hidden in UI)
  installByDefault Boolean  @default(false) // checked-by-default in install wizard
  assetName        String?  // GitHub Release asset filename pattern, e.g. "module-robot_piper-{version}.tar.gz"
  dependencies     String[] @default([])    // module ids this depends on; usually empty

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments     Payment[]
  entitlements Entitlement[]
}

// User owns this module forever (one-time purchase, account-scoped).
model Entitlement {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  paymentId String?  // null for free modules / admin-granted
  grantedAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  Module   @relation(fields: [moduleId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([userId, moduleId])
  @@index([userId])
}

// Each PortOne payment attempt. Source of truth for billing history.
// A payment is tied to either a Module (digital, software entitlement) OR an
// Order (physical hardware shipment) — exactly one of moduleId / orderId is
// non-null.
model Payment {
  id               String    @id @default(cuid())
  userId           String
  moduleId         String?
  orderId          String?
  portonePaymentId String    @unique // paymentId we send to PortOne
  status           String    @default("PENDING") // PENDING | PAID | FAILED | CANCELLED | REFUNDED
  amountKrw        Int
  method           String?   // CARD | KAKAOPAY | TOSSPAY | NAVERPAY | ...
  pgProvider       String?   // tosspayments | kakaopay | ...
  receiptUrl       String?
  paidAt           DateTime?
  cancelledAt      DateTime?
  raw              Json?     // last PortOne response for debugging
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      Module?       @relation(fields: [moduleId], references: [id])
  order       Order?        @relation(fields: [orderId], references: [id])
  entitlement Entitlement[]

  @@index([userId])
  @@index([orderId])
}

// PortOne-issued billing key for repeat charges. We never store the raw PAN.
model BillingKey {
  id         String   @id @default(cuid())
  userId     String
  billingKey String   @unique
  cardName   String?  // e.g. "신한카드"
  cardLast4  String?
  isDefault  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Hardware product catalog (e.g. leader robots). Visible to logged-in users
// in /store. Sold via the regular PortOne checkout flow.
//
// Variant model:
//   - If `variants` is empty, Product.priceKrw / Product.stock are used as-is.
//   - If `variants` exist, customer must pick one; variant.priceKrw / .stock
//     override Product values for the selected option.
model Product {
  id           String   @id @default(cuid())
  // Optional: when variants exist, the variant SKUs are the actual fulfillment
  // identifiers; Product.sku is only used as the unit SKU for variant-less
  // products. Unique among non-null values.
  sku          String?  @unique
  name         String
  description  String?
  priceKrw     Int
  stock        Int      @default(0)
  weightG      Int?
  leadTimeDays Int?
  imageUrl     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems OrderItem[]
  variants   ProductVariant[]
}

// Single-axis variants (e.g. "빨강", "L 사이즈", "v1.0 좌수형"). The variant
// owns its own price + stock.
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String   @unique
  priceKrw  Int
  stock     Int      @default(0)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
}

// One purchase = one Order, even with multiple OrderItems. Address fields
// are denormalized so editing the user's profile later doesn't change a
// shipped order's record.
model Order {
  id            String   @id @default(cuid())
  userId        String
  status        String   @default("PENDING") // PENDING | PAID | SHIPPED | DELIVERED | CANCELLED | REFUNDED
  totalKrw      Int
  recipientName String
  phone         String
  postalCode    String
  addressLine1  String
  addressLine2  String?
  requestNote   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  payments Payment[]
  shipment Shipment?

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id               String @id @default(cuid())
  orderId          String
  productId        String
  productName      String // snapshot at time of order
  productSku       String
  productVariantId String?
  variantName      String? // snapshot
  variantSku       String?
  quantity         Int
  unitPriceKrw     Int

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  variant ProductVariant?  @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
}

// User's saved shipping addresses, available as quick-fill in OrderForm.
model Address {
  id            String   @id @default(cuid())
  userId        String
  label         String?  // "집", "회사" 등 (optional)
  recipientName String
  phone         String
  postalCode    String
  addressLine1  String
  addressLine2  String?
  requestNote   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 1:1 with Order. Created when admin enters tracking number.
model Shipment {
  id             String    @id @default(cuid())
  orderId        String    @unique
  courier        String    // "CJ" | "한진" | "우체국" | "롯데" | etc
  trackingNumber String
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
