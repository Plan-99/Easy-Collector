{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run setup:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/manual-update-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/frontend-i18n-check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/frontend-no-css.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/frontend-ui-test-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
